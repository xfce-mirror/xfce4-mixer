#. Add menu item for muting
#: panel-plugin/xfce-mixer-plugin.c:301
msgid "Mu_te"
msgstr "_Tắt tiếng"

#. Add menu item for running the user-defined command
#: panel-plugin/xfce-mixer-plugin.c:307
msgid "Run Audio Mi_xer"
msgstr "Mở _Bộ điều chỉnh âm thanh"

#: panel-plugin/xfce-mixer-plugin.c:575
#: xfce4-mixer/xfce-mixer-application.c:157
msgid ""
"GStreamer was unable to detect any sound devices. Some sound system specific"
" GStreamer packages may be missing. It may also be a permissions problem."
msgstr "GStreamer không phát hiện được thiết bị âm thanh nào. Có thể thiếu một số gói GStreamer dành cho hệ thống âm thanh cụ thể, hoặc do vấn đề quyền truy cập."

#: panel-plugin/xfce-mixer-plugin.c:949
msgid "No command defined"
msgstr "Chưa xác định lệnh"

#. Generate error message and insert the current command
#: panel-plugin/xfce-mixer-plugin.c:957
#, c-format
msgid ""
"Could not execute the command \"%s\". Ensure that either the location of the"
" command is included in the PATH environment variable or that you are "
"providing the full path to the command."
msgstr "Không thể thực thi lệnh \"%s\". Hãy đảm bảo rằng đường dẫn tới lệnh đã nằm trong biến môi trường PATH hoặc bạn đang cung cấp đường dẫn đầy đủ tới lệnh."

